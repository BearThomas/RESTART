[
{
  "id": "event_military_day1",
  "type": "story",
  "name": "军训 · 第一天",
  "desc": "军训第一天，教官给了个下马威。站军姿站到腿软，但你知道这只是开始。",
  "once": true,
  "condition": "day == 1",
  "options": null,
  "autoEffects": [{ "str": 1 }],
  "weight": 1000
},
{
  "id": "event_military_day2",
  "type": "story",
  "name": "军训 · 第二天",
  "desc": "全身酸痛，但还得继续。今天的训练是齐步走，你的步伐越来越整齐了。",
  "once": true,
  "condition": "day == 2",
  "options": null,
  "autoEffects": [{ "str": 1 }],
  "weight": 1000
},
{
  "id": "event_military_day3",
  "type": "story",
  "name": "军训 · 第三天",
  "desc": "身体逐渐适应了训练强度。今天练习正步走，教官夸你有进步。",
  "once": true,
  "condition": "day == 3",
  "options": null,
  "autoEffects": [{ "str": 1 }],
  "weight": 1000
},
{
  "id": "event_military_day4",
  "type": "story",
  "name": "军训 · 第四天",
  "desc": "今天教唱军歌，你扯着嗓子吼得最大声。虽然跑调了，但气势很足！",
  "once": true,
  "condition": "day == 4",
  "options": null,
  "autoEffects": [{ "str": 1 }],
  "weight": 1000
},
{
  "id": "event_military_day5",
  "type": "story",
  "name": "军训 · 第五天",
  "desc": "军训最后一天，汇报演出圆满成功。和教官告别时，竟然有点舍不得。",
  "once": true,
  "condition": "day == 5",
  "options": null,
  "autoEffects": [{ "str": 1 }],
  "weight": 1000
},
{
  "id": "event_opening",
  "type": "story",
  "name": "开学典礼",
  "desc": "校长在台上激情演讲，把上学期的内容又讲了一遍……你坐在下面昏昏欲睡。",
  "once": true,
  "condition": "day == 6",
  "options": null,
  "autoEffects": [],
  "weight": 10000
},
{
  "id": "event_canteen_fall",
  "type": "story",
  "name": "抢饭时摔了一跤",
  "desc": "中午下课铃一响，你以百米冲刺的速度奔向食堂，结果在门口脚下一滑，摔了个四脚朝天……第二天，学校通报了这起'拥挤踩踏隐患事件'。",
  "once": false,
  "options": null,
  "autoEffects": [{ "str": -2 }],
  "weight": 4
},
{
  "id": "event_canteen_success",
  "type": "story",
  "name": "抢饭成功",
  "desc": "中午下课铃一响，你以百米冲刺的速度奔向食堂，成功抢饭！",
  "once": false,
  "options": null,
  "autoEffects": [{ "hap": 2 }],
  "weight": 4
},
{
  "id": "event_shower_queue",
  "type": "story",
  "name": "抢不到洗澡位",
  "desc": "放学后你冲向宿舍，却发现最后一个位置被前面的同学抢先一步占了。你只能闻着自己的汗味，心情低落……",
  "once": false,
  "options": null,
  "condition": "day > 6",
  "autoEffects": [
    { "hap": -3 },
    { "cha": -2 }
  ],
  "weight": 5
},
{
  "id": "event_shower_queue_2",
  "type": "story",
  "name": "抢到洗澡位",

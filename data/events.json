{
  "id": "event_sports_meeting",
  "type": "sports",
  "name": "运动会",
  "desc": "学校举办运动会，班主任正在征集报名。你打算参加吗？",
  "once": true,
  "condition": "day > 6",
  "weight": 10,
  "options": [
    {
      "text": "不参加",
      "desc": "当个观众也挺好，无事发生",
      "effects": []
    },
    {
      "text": "参加跳绳比赛",
      "desc": "体质+5，50%概率获奖",
      "effects": [{ "str": 5 }],
      "chainEvent": {
        "name": "跳绳比赛",
        "desc": "你参加了跳绳比赛……",
        "probability": 1,
        "options": null,
        "outcomes": [
          {
            "probability": 0.5,
            "name": "获奖了！",
            "desc": "你跳得又快又稳，拿到了名次！",
            "effects": [{ "hap": 5 }],
            "achievement": "won_award_in_sports_meet"
          },
          {
            "probability": 0.5,
            "name": "没获奖",
            "desc": "竞争太激烈了，你没有拿到名次……",
            "effects": [{ "hap": -5 }]
          }
        ]
      }
    },
    {
      "text": "参加跑步比赛",
      "desc": "体质+7，20%概率获奖",
      "effects": [{ "str": 7 }],
      "chainEvent": {
        "name": "跑步比赛",
        "desc": "你站在起跑线上，心跳加速……",
        "probability": 1,
        "options": null,
        "outcomes": [
          {
            "probability": 0.2,
            "name": "获奖了！",
            "desc": "你奋力冲刺，成功站上了领奖台！",
            "effects": [{ "hap": 5 }],
            "achievement": "won_award_in_sports_meet"
          },
          {
            "probability": 0.8,
            "name": "没获奖",
            "desc": "你已经尽力了，但对手实在太强……",
            "effects": [{ "hap": -5 }]
          }
        ]
      }
    },
    {
      "text": "参加跳远比赛",
      "desc": "体质+2，70%概率获奖",
      "effects": [{ "str": 2 }],
      "chainEvent": {
        "name": "跳远比赛",
        "desc": "你助跑、起跳……",
        "probability": 1,
        "options": null,
        "outcomes": [
          {
            "probability": 0.7,
            "name": "获奖了！",
            "desc": "你纵身一跃，跳出了个人最好成绩！",
            "effects": [{ "hap": 5 }],
            "achievement": "won_award_in_sports_meet"
          },
          {
            "probability": 0.3,
            "name": "没获奖",
            "desc": "差一点点就能拿奖了，好可惜……",
            "effects": [{ "hap": -5 }]
          }
        ]
      }
    }
  ]

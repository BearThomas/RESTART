  "once": false,
  "options": null,
  "condition": "day > 6",
  "autoEffects": [
    { "hap": 3 },
    { "cha": 2 }
  ],
  "weight": 5
},
{
  "id": "event_oath_mistake",
  "type": "story",
  "name": "宣誓口误",
  "desc": "升旗仪式上，某人带领大家宣誓时太紧张，把'龙高人'说成了'龙高棱'……台下憋笑声一片，你也忍不住笑了。",
  "once": false,
  "condition": "day % 7 == 1 && day > 6",
  "options": null,
  "autoEffects": [
    { "int": -1 },
    { "hap": 2 }
  ],
  "weight": 5
},
{
  "id": "event_homework_crisis",
  "type": "study",
  "name": "作业写不完",
  "desc": "晚自习快结束了，你看着桌上堆积如山的作业，陷入了沉思……今晚肯定写不完了，你决定：",
  "once": false,
  "weight": 5,
  "condition": "day > 6 && !hasTalent('talent_gentleman') && !hasTalent('talent_three_good')",
  "options": [
    {
      "text": "抄作业",
      "desc": "智力-5，快乐+5，5%概率被老师发现",
      "effects": [
        { "int": -5 },
        { "hap": 5 }
      ],
      "chainEvent": {
        "name": "抄作业被发现",
        "desc": "老师火眼金睛，一眼就看出你的作业是抄的！被叫到办公室写了一晚上检讨……",
        "probability": 0.05,
        "options": null,
        "autoEffects": [{ "hap": -10 }]
      }
    },
    {
      "text": "写不完就写不完吧",
      "desc": "无影响，第二天50%概率被老师骂",
      "effects": [],
      "chainEvent": {
        "name": "被老师骂了",
        "desc": "第二天老师当众批评了你没交作业，有点丢脸……",
        "probability": 0.5,
        "options": null,
        "autoEffects": [{ "hap": -5 }]
      }
    },
    {
      "text": "晚上熬夜写",
      "desc": "智力+5，体质-5，3%概率被宿管抓",
      "effects": [
        { "int": 5 },
        { "str": -5 }
      ],
      "chainEvent": {
        "name": "被宿管抓到了",
        "desc": "深夜，你的台灯微光被巡楼的宿管发现了……被记了一次违纪，心情跌到谷底。",
        "probability": 0.03,
        "options": null,
        "autoEffects": [{ "hap": -10 }]
      }
    }
  ]
},
